{
  "name": "md-rehman.dev",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\" --ignore-path .gitignore",
    "generate:app": "node scripts/generate-app.mjs",
    "generate:package": "node scripts/generate-package.mjs",
    "preinstall": "npx only-allow yarn"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@shopify/react-native-skia": "*",
    "eslint": "^8.57.0",
    "minimatch": "^10.2.5",
    "next": "16.2.9",
    "prettier": "^3.2.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.85.3",
    "react-native-web": "*",
    "turbo": "2.9.18",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18",
    "yarn": ">=1.22.0"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
